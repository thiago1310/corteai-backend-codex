            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  if (data.access_token) pm.environment.set('jwtToken', data.access_token);",
                  "}"
                ]
