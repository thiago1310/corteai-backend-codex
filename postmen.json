            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Cliente Teste\",\n  \"email\": \"cliente@example.com\",\n  \"senha\": \"123456\",\n  \"telefone\": \"48999999999\",\n  \"cpfCnpj\": \"12345678901\",\n  \"status\": \"ativo\",\n  \"plano\": \"basico\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register/cliente",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register",
                "cliente"
              ]
            }
